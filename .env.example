# ----------------------------------------------------------------------------
# Art Explore Backend — Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# All variables are validated at startup (src/config/env.ts) via Zod —
# a missing or malformed value crashes the app with a clear message.
# ----------------------------------------------------------------------------

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/art_explore?schema=public"

# JWT
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# AWS S3 (gallery images only)
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="eu-west-1"
AWS_S3_BUCKET_NAME="art-explore-images"

# Upstash Redis (refresh tokens + response cache only)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Default Super Admin (used by prisma/seed.ts)
SEED_SUPER_ADMIN_NAME="Art Explore Admin"
SEED_SUPER_ADMIN_EMAIL="admin@artexplore.africa"
SEED_SUPER_ADMIN_PASSWORD="change-me-on-first-login"
